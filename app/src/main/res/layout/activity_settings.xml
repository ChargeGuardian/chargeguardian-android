<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛡️ ChargeGuardian"
        android:textColor="@color/gold"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_language"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnLangToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_lang_desc"
        android:backgroundTint="@color/bg_surface"
        android:textColor="@color/gold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_whitelist"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_whitelist_desc"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_about"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:paddingTop="24dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_about_desc"
        android:textColor="@color/text_hint"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="chargeguardian.io"
        android:textColor="@color/gold"
        android:autoLink="web"
        android:textSize="14sp"
        android:paddingTop="4dp" />

</LinearLayout>
